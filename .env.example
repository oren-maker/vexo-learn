# --- Database (Supabase / Neon / Vercel Postgres) ---
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/db?schema=public"

# --- Gemini ---
GEMINI_API_KEY="AIza..."

# --- Vercel Blob (auto-populated by Vercel when Blob is enabled) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- External APIs (optional) ---
PEXELS_API_KEY=""
GITHUB_TOKEN=""

# --- Internal auth (service-to-service: AI Director, CeDance sync) ---
INTERNAL_API_KEY="change-me-long-random-string"
