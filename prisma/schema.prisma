generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model LearnSource {
  id         String   @id @default(cuid())
  type       String   // "instructor_url" | "cedance" | "free_api" | "upload"
  url        String?
  prompt     String
  title      String?
  thumbnail  String?
  duration   Int?
  blobUrl    String?  // Vercel Blob URL or external MP4 URL
  externalId String?  @unique
  status     String   @default("pending") // pending | processing | complete | failed
  error      String?
  addedBy    String?
  pdfBlobUrl String?
  pdfGeneratedAt DateTime?
  parentSourceId String?
  parentSource   LearnSource?  @relation("Lineage", fields: [parentSourceId], references: [id], onDelete: SetNull)
  children       LearnSource[] @relation("Lineage")
  lineageNotes   String?       // what was borrowed/adapted from parent (short paragraph)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  analysis   VideoAnalysis?
  subscriberPrompts SubscriberPrompt[]

  @@index([status])
  @@index([type])
}

model VideoAnalysis {
  id              String   @id @default(cuid())
  sourceId        String   @unique
  source          LearnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  description     String
  techniques      String[] @default([])
  howTo           String[] @default([])
  tags            String[] @default([])
  style           String?
  mood            String?
  difficulty      String?
  insights        String[] @default([])
  promptAlignment Int?
  rawGemini       String
  createdAt       DateTime @default(now())
  knowledgeNodes  KnowledgeNode[]
}

model KnowledgeNode {
  id             String   @id @default(cuid())
  type           String   // "technique" | "style" | "how_to" | "insight"
  title          String
  body           String
  tags           String[] @default([])
  confidence     Float    @default(0.8)
  analysisId     String
  analysis       VideoAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  sentToDirector Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([sentToDirector])
  @@index([type])
}

model SubscriberPrompt {
  id        String   @id @default(cuid())
  userId    String
  sourceId  String
  source    LearnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  viewed    Boolean  @default(false)
  saved     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiUsage {
  id           String   @id @default(cuid())
  engine       String   // "gemini" | "claude" | "gemini-image"
  model        String
  operation    String   // "compose" | "improve" | "video-analysis" | "image-gen" | "knowledge-extract"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  imagesOut    Int      @default(0)
  videoSeconds Int      @default(0)
  usdCost      Float    @default(0)
  sourceId     String?
  meta         Json?
  errored      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([engine])
  @@index([operation])
}

model GeneratedImage {
  id         String   @id @default(cuid())
  sourceId   String
  blobUrl    String
  model      String
  usdCost    Float    @default(0)
  promptHead String   @db.Text
  createdAt  DateTime @default(now())

  @@index([sourceId])
  @@index([createdAt])
}

model GeneratedVideo {
  id              String   @id @default(cuid())
  sourceId        String
  blobUrl         String
  model           String
  usdCost         Float    @default(0)
  durationSec     Int      @default(8)
  aspectRatio     String   @default("16:9")
  promptHead      String   @db.Text
  status          String   @default("pending") // submitting | rendering | downloading | uploading | complete | failed
  progressPct     Int      @default(0)
  progressMessage String?
  operationId     String?
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
}
