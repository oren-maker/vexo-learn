{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/learn/sources/route.ts": { "maxDuration": 300 },
    "app/api/learn/search/analyze/route.ts": { "maxDuration": 300 },
    "app/api/cron/sync-seedance/route.ts": { "maxDuration": 300 },
    "app/learn/sources/new/page.tsx": { "maxDuration": 300 },
    "app/learn/sources/[id]/page.tsx": { "maxDuration": 300 },
    "app/api/learn/pattern-extract/route.ts": { "maxDuration": 300 },
    "app/api/cron/insights-snapshot/route.ts": { "maxDuration": 300 },
    "app/api/video/jobs/[id]/run/route.ts": { "maxDuration": 300 },
    "app/api/video/transitions/generate/route.ts": { "maxDuration": 300 },
    "app/api/video/trim/sessions/[id]/rate/route.ts": { "maxDuration": 300 },
    "app/api/video/trim/ai-detect/route.ts": { "maxDuration": 300 },
    "app/api/cron/daily-brain/route.ts": { "maxDuration": 300 },
    "app/api/learn/brain/refresh/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/cron/sync-seedance", "schedule": "0 3 * * *" },
    { "path": "/api/cron/insights-snapshot", "schedule": "0 * * * *" },
    { "path": "/api/cron/daily-brain", "schedule": "0 1 * * *" }
  ]
}
